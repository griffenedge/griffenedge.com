<div class="container">
  <section class="content my-5">
    <img
      class="intro-section-media"
      src="/assets/images/griffen-edge-2024.jpg"
      alt="Griffen's smiling bespectacled face"
    />
    <h1 class="h1">
      <strong>Hey there, I'm Griffen</strong>, a user experience designer who
      creates accessible and inclusive solutions that empower everyday people
    </h1>
    <p class="lead">
      I'm a UX/UI Designer at
      <a href="https://www.ssw.com.au/">SSW Australia</a>, with experience
      across education, government, health & aged care, and insurance.
    </p>
  </section>
  <nav aria-label="Projects">
    <section id="case-studies" class="my-5">
      <h2>Case studies</h2>
      <ul class="projects">
        {%- for project in collections["case-study"] | reverse -%}
          {% include "project-card.njk" %}
        {%- endfor -%}
      </ul>
    </section>
    <section class="my-5">
      <h2>Other work</h2>
      <ul class="projects">
        {%- for project in collections["other-work"] | reverse -%}
          {% include "project-card.njk" %}
        {%- endfor -%}
      </ul>
    </section>
  </nav>
</div>
